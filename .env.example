# ============================================
# FEMS Environment Configuration
# ============================================
# For local development: copy this file to .env
# For production (Render): set environment variables in dashboard

# ============================================
# DATABASE
# ============================================
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://ikennykelvin75_db_user:PASSWORD@fire-cluster0.mo4ild4.mongodb.net/?appName=Fire-Cluster0

# ============================================
# SERVICE PORTS (Local Development)
# ============================================
USER_PORT=4001
EXT_PORT=4002
INSP_PORT=4003
REPORT_PORT=4004
EMAIL_PORT=4005
WEBSOCKET_PORT=4006
GATEWAY_PORT=4000

# ============================================
# SERVICE URLS (Microservice Communication)
# ============================================
# For local development:
USER_URL=http://localhost:4001
EXT_URL=http://localhost:4002
INSP_URL=http://localhost:4003
REPORT_URL=http://localhost:4004
EMAIL_URL=http://localhost:4005
WEBSOCKET_URL=http://localhost:4006

# For Render deployment (update with actual Render service URLs):
# USER_URL=https://fems-user-service.onrender.com
# EXT_URL=https://fems-extinguisher-service.onrender.com
# INSP_URL=https://fems-inspection-service.onrender.com
# REPORT_URL=https://fems-reporting-service.onrender.com
# EMAIL_URL=https://fems-email-service.onrender.com
# WEBSOCKET_URL=https://fems-websocket-service.onrender.com

# ============================================
# SECURITY
# ============================================
JWT_SECRET=change-this-to-a-secure-random-string-in-production
BCRYPT_ROUNDS=10
NODE_ENV=development

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Using Gmail/SMTP:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Using SendGrid:
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@fems.com

# ============================================
# FRONTEND URLS (for CORS)
# ============================================
# Production:
FRONTEND_URL=https://fire-tawny-mu.vercel.app
# Local dev:
# FRONTEND_URL=http://localhost:5173

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# Production: use 'warn' or 'error'

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# ============================================
# CORS SETTINGS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# OPTIONAL: REDIS (for caching/sessions)
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# FEATURE FLAGS
# ============================================
STRICT_EXT_CHECK=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WEBSOCKET=true
